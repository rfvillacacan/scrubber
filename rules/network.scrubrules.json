{
    "ruleset_id": "NETWORK",
    "version": "1.1.0",
    "description": "Network and infrastructure identifiers",
    "author": "Security",
    "priority_base": 700,
    "rules": [
        {
            "id": "CIDR",
            "enabled": true,
            "priority": 120,
            "pattern": "(?<!\\d)(?:\\d{1,3}\\.){3}\\d{1,3}\\/\\d{1,2}(?!\\d)",
            "flags": "",
            "validation": "cidr_strict"
        },
        {
            "id": "IPV4",
            "enabled": true,
            "priority": 110,
            "pattern": "(?<!\\d)(?:\\d{1,3}\\.){3}\\d{1,3}(?!\\d)",
            "flags": "",
            "validation": "ipv4_strict"
        },
        {
            "id": "IPV6",
            "enabled": true,
            "priority": 105,
            "pattern": "\\b[0-9A-Fa-f]{0,4}:(?:[0-9A-Fa-f:]{2,})\\b",
            "flags": "",
            "validation": "ipv6_strict"
        },
        {
            "id": "INTERNAL_HOST",
            "enabled": true,
            "priority": 95,
            "pattern": "\\b[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9-]{1,63})*\\.(?:corp|internal|local|lan)\\b",
            "flags": "i",
            "validation": null
        },
        {
            "id": "MAC_ADDRESS",
            "enabled": true,
            "priority": 90,
            "pattern": "\\b(?:[0-9A-Fa-f]{2}[:-]){5}[0-9A-Fa-f]{2}\\b",
            "flags": "",
            "validation": null
        },
        {
            "id": "POD_NAME",
            "enabled": true,
            "priority": 85,
            "pattern": "\\b[a-z0-9-]+-[a-f0-9]{8,10}(?:-[a-z0-9]{4,10})?\\b",
            "flags": "i",
            "validation": null
        }
    ]
}