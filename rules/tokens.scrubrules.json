{
    "ruleset_id": "TOKENS",
    "version": "1.2.0",
    "description": "Credentials, tokens, secrets, and key material",
    "author": "Security",
    "priority_base": 900,
    "rules": [
        {
            "id": "PRIVATE_KEY_BLOCK",
            "enabled": true,
            "priority": 200,
            "pattern": "(-----BEGIN(?:[A-Z ]+)?PRIVATE KEY-----[\\s\\S]+?-----END(?:[A-Z ]+)?PRIVATE KEY-----)",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "CERT_BLOCK",
            "enabled": true,
            "priority": 195,
            "pattern": "(-----BEGIN CERTIFICATE-----[\\s\\S]+?-----END CERTIFICATE-----)",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "URL_BASIC_AUTH",
            "enabled": true,
            "priority": 190,
            "pattern": "\\b([a-z][a-z0-9+.-]*:\\/\\/[^:\\s\\/]+:[^@\\s\\/]+@[^\\/\\s]+(?:\\/[\\S]*)?)",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "BEARER_TOKEN",
            "enabled": true,
            "priority": 188,
            "pattern": "\\bBearer\\s+([A-Za-z0-9._=-]{10,}(?:\\.[A-Za-z0-9._=-]{4,}){1,})\\b",
            "flags": "i",
            "validation": null,
            "generator": "bearerToken",
            "cache_type": "global",
            "data_type": "token",
            "skip_length_adjust": true
        },
        {
            "id": "BASIC_AUTH",
            "enabled": true,
            "priority": 187,
            "pattern": "\\bAuthorization\\s*:\\s*Basic\\s+([A-Za-z0-9+\\/=]{12,})\\b",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "API_KEY_HEADER",
            "enabled": true,
            "priority": 186,
            "pattern": "\\b(?:X-API-KEY|X-APIKEY|API-KEY|APIKEY|X-AUTH-TOKEN|X-ACCESS-TOKEN|X-TOKEN|X-API-TOKEN|X-CLIENT-SECRET|X-CLIENT-TOKEN)\\s*:\\s*([^\\s,;]{8,})",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "API_KEY_QUERY",
            "enabled": true,
            "priority": 185,
            "pattern": "[?&](?:api_key|apikey|access_token|auth_token|token|key|client_secret|client_token)=([A-Za-z0-9._~%+-]{8,})",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "API_KEY_COOKIE",
            "enabled": true,
            "priority": 184,
            "pattern": "\\b(?:Cookie|Set-Cookie)\\s*:\\s*[^\\n]*?(?:api_key|apikey|access_token|auth_token|token)=([^;\\s]{8,})",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "SESSION_COOKIE",
            "enabled": true,
            "priority": 183,
            "pattern": "\\b(?:JSESSIONID|SESSIONID|SESSION|SID|PHPSESSID)=([A-Za-z0-9._-]{16,})\\b",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "TRACE_ID",
            "enabled": true,
            "priority": 182,
            "pattern": "\\b(?:REQUEST-ID|REQUEST_ID|TRACE-ID|TRACE_ID)\\s*[:=]\\s*([A-F0-9-]{16,})\\b",
            "flags": "i",
            "validation": null,
            "generator": "uuid",
            "cache_type": "global",
            "data_type": "uuid",
            "skip_length_adjust": true
        },
        {
            "id": "UUID",
            "enabled": true,
            "priority": 181,
            "pattern": "\\b([0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})\\b",
            "flags": "i",
            "validation": null,
            "generator": "uuid",
            "cache_type": "global",
            "data_type": "uuid",
            "skip_length_adjust": true
        },
        {
            "id": "JDBC_URL",
            "enabled": true,
            "priority": 180,
            "pattern": "\\b(jdbc:[a-z0-9+.-]+:\\/\\/[^\\s]+)",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "PASSWORD_ASSIGN",
            "enabled": true,
            "priority": 170,
            "pattern": "\\b(?:DB_PASS|DB_PASSWORD|PASSWORD|PASS|SECRET|APP_SECRET|API_KEY|TOKEN|ACCESS_KEY|SECRET_KEY)\\s*=\\s*([A-Za-z0-9][^\\s\"',;]*)",
            "flags": "i",
            "validation": null,
            "generator": "password",
            "cache_type": "local"
        },
        {
            "id": "USERNAME_ASSIGN",
            "enabled": true,
            "priority": 165,
            "pattern": "\\b(?:DB_USER|USER|USERNAME)\\s*=\\s*([A-Za-z0-9._-]{3,})(?!@)",
            "flags": "i",
            "validation": null,
            "generator": "username",
            "cache_type": "local"
        },
        {
            "id": "SMTP_PASSWORD",
            "enabled": true,
            "priority": 164,
            "pattern": "SMTP_PASS\\s*=\\s*([^\\s]{8,})",
            "flags": "i",
            "validation": null,
            "generator": "password",
            "cache_type": "local"
        },
        {
            "id": "DB_NAME",
            "enabled": true,
            "priority": 163,
            "pattern": "\\bDB_NAME\\s*=\\s*([A-Za-z0-9_]{3,})",
            "flags": "i",
            "validation": null,
            "generator": "databaseName",
            "cache_type": "local"
        },
        {
            "id": "JWT_EYJ",
            "enabled": true,
            "priority": 160,
            "pattern": "((?<![A-Za-z0-9_-])eyJ[A-Za-z0-9_-]*(?:\\.[A-Za-z0-9_-]+){2,}(?![A-Za-z0-9_-]))",
            "flags": "",
            "validation": "jwt_structure",
            "generator": "jwt",
            "cache_type": "global",
            "data_type": "jwt",
            "skip_length_adjust": true
        },
        {
            "id": "JWT",
            "enabled": true,
            "priority": 158,
            "pattern": "((?<![A-Za-z0-9_-])[A-Za-z0-9_-]{10,}(?:\\.[A-Za-z0-9_-]{10,}){2,}(?![A-Za-z0-9_-]))",
            "flags": "",
            "validation": "jwt_structure",
            "generator": "jwt",
            "cache_type": "global",
            "data_type": "jwt",
            "skip_length_adjust": true
        },
        {
            "id": "STRIPE_KEY",
            "enabled": true,
            "priority": 155,
            "pattern": "\\b(sk_(?:test|live)_[A-Za-z0-9]{16,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "STRIPE_PUBLISHABLE",
            "enabled": true,
            "priority": 154,
            "pattern": "\\b(pk_(?:test|live)_[A-Za-z0-9]{16,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "OPENAI_KEY",
            "enabled": true,
            "priority": 153,
            "pattern": "\\b(sk-[A-Za-z0-9]{16,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "ANTHROPIC_KEY",
            "enabled": true,
            "priority": 152,
            "pattern": "\\b(sk-ant-[A-Za-z0-9_-]{16,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "AWS_ACCESS_KEY",
            "enabled": true,
            "priority": 151,
            "pattern": "\\b(AKIA[0-9A-Z]{16})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "GOOGLE_API_KEY",
            "enabled": true,
            "priority": 150,
            "pattern": "\\b(AIza[0-9A-Za-z_-]{30,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "SLACK_TOKEN",
            "enabled": true,
            "priority": 149,
            "pattern": "\\b(xox[baprs]-[A-Za-z0-9-]{10,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "SENDGRID_KEY",
            "enabled": true,
            "priority": 148,
            "pattern": "\\b(SG\\.[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "TWILIO_KEY",
            "enabled": true,
            "priority": 147,
            "pattern": "\\b(AC[a-f0-9]{32})\\b",
            "flags": "i",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "MAILGUN_KEY",
            "enabled": true,
            "priority": 146,
            "pattern": "\\b(key-[A-Za-z0-9]{20,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "MAPBOX_TOKEN",
            "enabled": true,
            "priority": 145,
            "pattern": "\\b((?:pk|sk)\\.[A-Za-z0-9]{20,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "GITHUB_TOKEN",
            "enabled": true,
            "priority": 144,
            "pattern": "\\b(ghp_[A-Za-z0-9]{20,})\\b",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        },
        {
            "id": "BASE64_BLOB",
            "enabled": false,
            "priority": 120,
            "pattern": "(?<![A-Za-z0-9+\\/=])[A-Za-z0-9+\\/]{24,}={0,2}(?![A-Za-z0-9+\\/=])",
            "flags": "",
            "validation": null,
            "generator": "string",
            "cache_type": "local"
        }
    ]
}