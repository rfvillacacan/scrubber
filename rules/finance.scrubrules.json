{
    "ruleset_id": "FINANCE",
    "version": "1.1.0",
    "description": "Banking and financial identifiers",
    "author": "Security",
    "priority_base": 900,
    "rules": [
        {
            "id": "IBAN",
            "enabled": true,
            "priority": 150,
            "pattern": "\\b[A-Z]{2}\\d{2}[A-Z0-9]{11,30}\\b",
            "flags": "i",
            "validation": "iban"
        },
        {
            "id": "SWIFT_BIC",
            "enabled": true,
            "priority": 145,
            "pattern": "\\b(?:SWIFT|BIC)(?:\\/BIC)?\\s*[:=]?\\s*[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}(?:[A-Z0-9]{3})?\\b",
            "flags": "i",
            "validation": null
        },
        {
            "id": "ROUTING_ABA",
            "enabled": true,
            "priority": 140,
            "pattern": "\\b\\d{9}\\b",
            "flags": "",
            "validation": "routing_aba"
        },
        {
            "id": "ACCOUNT_NUMBER",
            "enabled": true,
            "priority": 130,
            "pattern": "\\b(?:ACCOUNT NUMBER|ACCT)\\s*[:=]?\\s*\\d{8,18}\\b",
            "flags": "i",
            "validation": null
        },
        {
            "id": "PAYMENT_TOKEN",
            "enabled": true,
            "priority": 125,
            "pattern": "\\btok_[A-Za-z0-9]{10,}\\b",
            "flags": "",
            "validation": null
        },
        {
            "id": "PAYPAL_TOKEN",
            "enabled": true,
            "priority": 124,
            "pattern": "\\bA21[A-Za-z0-9]{10,}\\b",
            "flags": "",
            "validation": null
        },
        {
            "id": "EXPIRY",
            "enabled": true,
            "priority": 120,
            "pattern": "\\b(?:EXPIRY|EXP|EXPIRATION)\\s*[:=]?\\s*(?:0[1-9]|1[0-2])\\/\\d{2}\\b",
            "flags": "i",
            "validation": null
        }
    ]
}