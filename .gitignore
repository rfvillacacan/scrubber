# Environment
.env
.env.local

# Runtime data
/data/*
!/data/.gitkeep
!/data/logs/
/data/logs/*
!/data/logs/.gitkeep

# Certificates and secrets
/certs/*
!/certs/.gitkeep

# Local cleanup archives and backups
/archive/
*.bak
*.bak_*

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Docker/compose local overrides
docker-compose.override.yml

# Test artifacts
/tests/.server.log
/tests/.cookies.txt
/tests/.cookies2.txt
/tests/.resp.txt
